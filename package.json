{
    "name": "task-chatbot",
    "version": "1.0.0",
    "description": "Chatbot de tareas y horarios via WhatsApp",
    "main": "dist/main.js",
    "scripts": {
        "dev": "tsx --watch src/main.ts",
        "start": "npm run build && node dist/main.js",
        "build": "pnpm --filter @task-bot/* build && tsc",
        "clean": "rm -rf sessions .wwebjs_cache dist",
        "clean:all": "rm -rf sessions .wwebjs_cache node_modules",
        "lint": "eslint src --ext .ts",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@task-bot/db-core": "workspace:*",
        "@task-bot/telegram-core": "workspace:*",
        "@task-bot/whatsapp-core": "workspace:*",
        "dotenv": "16.4.5",
        "drizzle-orm": "^0.38.4",
        "express": "4.21.0",
        "p-limit": "^7.3.0",
        "pino": "9.5.0",
        "uuid": "11.0.3",
        "zod": "3.23.8"
    },
    "devDependencies": {
        "@neondatabase/serverless": "^1.1.0",
        "@types/express": "5.0.0",
        "@types/node": "22.9.0",
        "@types/uuid": "10.0.0",
        "drizzle-kit": "^0.31.10",
        "pino-pretty": "^13.1.3",
        "tsx": "4.19.2",
        "typescript": "5.6.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}