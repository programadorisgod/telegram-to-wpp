# ── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5199
LOG_LEVEL=info
BOT_WELCOME_MESSAGE="Bienvenido al bot"

# ── WhatsApp ──────────────────────────────────────────
WHATSAPP_SESSION_PATH=./sessions
CHROME_PATH=/usr/bin/chromium

# ── Telegram Bridge ──────────────────────────────────
BRIDGE_BOT_TOKEN=
TELEGRAM_GROUP_ID=0
BRIDGE_AUTHORIZED_WPP_IDS=

# ── Database (user_states for bridge state) ──────────
TURSO_URL=libsql://tu-db.turso.io
TURSO_TOKEN=

# ── Caches (ms) ──────────────────────────────────────
TTL_CACHE_USER_STATES=1800000
TTL_CACHE_SESSIONS=900000
TTL_CACHE_MESSAGES=300000

# ── Concurrency ───────────────────────────────────────
WHATSAPP_CONCURRENCY=3
